PORT=3000
NODE_ENV=development

# Resend — order confirmation emails (https://resend.com)
# 1. Sign up at resend.com and get an API key
# 2. Add and verify a sending domain (or use onboarding@resend.dev for testing)
# 3. Never commit the real values — add .env to .gitignore
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=orders@yourdomain.com
# Optional: redirect ALL confirmation emails to this address (useful in sandbox/demo mode)
# RESEND_TO_OVERRIDE=you@gmail.com